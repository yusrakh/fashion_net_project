{
  "version": 2,
  "builds": [
    {
      "src": "templates/*.html",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    { "src": "/", "dest": "/templates/index.html" },
    { "src": "/login", "dest": "/templates/login.html" },
    { "src": "/signup", "dest": "/templates/signup.html" },
    { "src": "/checkout", "dest": "/templates/checkout.html" },
    { "src": "/brand", "dest": "/templates/brand.html" },
    { "src": "/category", "dest": "/templates/category.html" },
    { "src": "/admin", "dest": "/templates/admin.html" },
    { "src": "/admin_login", "dest": "/templates/admin_login.html" }
  ]
}